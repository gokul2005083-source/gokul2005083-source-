<script>
/* LOADER */
window.addEventListener('load',()=>setTimeout(()=>document.getElementById('loader').classList.add('hidden'),1600));

/* THEME */
const html=document.documentElement;
const tBtn=document.getElementById('theme-btn');
const tIco=document.getElementById('theme-ico');
function setTheme(t){
  html.setAttribute('data-theme',t);
  tIco.className=t==='dark'?'fas fa-sun':'fas fa-moon';
  localStorage.setItem('gr-theme',t);
}
tBtn.addEventListener('click',()=>setTheme(html.getAttribute('data-theme')==='dark'?'light':'dark'));
const saved=localStorage.getItem('gr-theme');
if(saved)setTheme(saved);

/* NAV SCROLL */
const navEl=document.getElementById('nav');
window.addEventListener('scroll',()=>navEl.classList.toggle('scrolled',scrollY>50));

/* MOBILE MENU */
const ham=document.getElementById('ham');
const mob=document.getElementById('mob');
ham.addEventListener('click',()=>{
  mob.classList.toggle('open');
  ham.querySelector('i').className=mob.classList.contains('open')?'fas fa-times':'fas fa-bars';
});
function closeMob(){mob.classList.remove('open');ham.querySelector('i').className='fas fa-bars'}

/* Close drawer on outside tap */
document.addEventListener('click',e=>{
  if(mob.classList.contains('open')&&!mob.contains(e.target)&&!ham.contains(e.target)){closeMob();}
});

/* SMOOTH SCROLL for all internal links */
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    const id=a.getAttribute('href').slice(1);
    const target=document.getElementById(id);
    if(target){e.preventDefault();target.scrollIntoView({behavior:'smooth'});}
  });
});

/* SCROLL REVEAL */
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');obs.unobserve(e.target)}})
},{threshold:.08,rootMargin:'0px 0px -30px 0px'});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

/* PROJECT FILTER */
function filterP(cat,btn){
  document.querySelectorAll('.f-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.pj-card').forEach(c=>{
    const match=cat==='all'||c.getAttribute('data-cat')===cat;
    c.style.display=match?'flex':'none';
  });
  const fp=document.querySelector('.featured-card');
  if(fp)fp.style.display=(cat==='all'||fp.getAttribute('data-cat')===cat)?'block':'none';
}

/* RESUME BUTTON — scroll to section */
const resumeBtn=document.getElementById('resume-btn');
if(resumeBtn)resumeBtn.addEventListener('click',function(e){
  e.preventDefault();
  const rs=document.getElementById('resume');
  if(rs)rs.scrollIntoView({behavior:'smooth'});
});

/* CONTACT FORM */
function sendMsg(){
  const n=document.getElementById('fn').value.trim();
  const e=document.getElementById('fe').value.trim();
  const m=document.getElementById('fm').value.trim();
  if(!n||!e||!m){alert('Please fill in all fields.');return}
  window.location.href=`mailto:gokul2005.08.3@gmail.com?subject=Portfolio Contact from ${encodeURIComponent(n)}&body=${encodeURIComponent(m+'\n\nFrom: '+e)}`;
}

/* COUNTER ANIMATION */
const cntObs=new IntersectionObserver(entries=>{
  if(!entries[0].isIntersecting)return;
  document.querySelectorAll('.ic-num').forEach(el=>{
    const full=el.textContent;
    const num=parseInt(full.replace(/\D/g,''));
    const suffix=full.replace(/[\d]/g,'').trim();
    const start=Date.now(),dur=1800;
    const step=()=>{
      const p=Math.min((Date.now()-start)/dur,1);
      const ease=p<.5?2*p*p:-1+(4-2*p)*p;
      el.textContent=Math.floor(ease*num)+suffix;
      if(p<1)requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  });
  cntObs.disconnect();
},{threshold:.3});
const impGrid=document.querySelector('.impact-grid');
if(impGrid)cntObs.observe(impGrid);

/* RESUME TIMELINE & PROJECT ANIMATIONS */
const rvObs=new IntersectionObserver(entries=>{
  entries.forEach((e,i)=>{
    if(e.isIntersecting){
      setTimeout(()=>{
        e.target.classList.add('in');
        // Animate child elements
        e.target.querySelectorAll('.rv-tl-item,.rv-pj,.rv-skill-item').forEach((el,j)=>{
          setTimeout(()=>el.classList.add('in'),j*100);
        });
      },i*80);
      rvObs.unobserve(e.target);
    }
  });
},{threshold:.08,rootMargin:'0px 0px -30px 0px'});
document.querySelectorAll('.rv-section').forEach(el=>rvObs.observe(el));
</script>
</body>
</html>