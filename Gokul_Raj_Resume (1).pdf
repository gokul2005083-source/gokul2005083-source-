<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gokul Raj — Data Analyst & AI Developer</title>
<meta name="description" content="Gokul Raj — Data Analyst & AI Developer. Open to Germany. 10+ projects. Power BI, Python, SQL, Machine Learning.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=DM+Mono:wght@300;400;500&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
/* ══════════════════════════════════════
   VARIABLES
══════════════════════════════════════ */
:root {
  --paper:   #f4f1ea;
  --cream:   #ece8dc;
  --cream2:  #e4dfd2;
  --ink:     #0d0d0f;
  --ink2:    #2a2826;
  --muted:   #6b6660;
  --faint:   #a09a93;
  --gold:    #c9a84c;
  --gold-l:  #e4c070;
  --rust:    #b85c38;
  --teal:    #1a6b6b;
  --teal-l:  rgba(26,107,107,0.1);
  --line:    rgba(10,10,15,0.10);
  --line2:   rgba(10,10,15,0.05);
  --shadow:  0 4px 32px rgba(10,10,15,0.08);
  --r:       4px;
}
[data-theme="dark"] {
  --paper:   #0f0e0c;
  --cream:   #181612;
  --cream2:  #201e19;
  --ink:     #f0ece4;
  --ink2:    #c8c2b8;
  --muted:   #8a8278;
  --faint:   #5a5650;
  --gold:    #d4a84c;
  --gold-l:  #e8c06a;
  --rust:    #cc6a42;
  --teal:    #2a9a9a;
  --teal-l:  rgba(42,154,154,0.12);
  --line:    rgba(240,236,228,0.08);
  --line2:   rgba(240,236,228,0.04);
  --shadow:  0 4px 32px rgba(0,0,0,0.4);
}

/* ══════════════════════════════════════
   RESET
══════════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px}
body{
  background:var(--paper);color:var(--ink);
  font-family:'Outfit',sans-serif;
  line-height:1.6;overflow-x:hidden;
  transition:background .35s,color .35s;
}

/* NOISE */
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:9999;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  opacity:.5;
}

/* ══════════════════════════════════════
   LOADER
══════════════════════════════════════ */
#loader{
  position:fixed;inset:0;z-index:9998;
  background:var(--paper);
  display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1.25rem;
  transition:opacity .6s,visibility .6s;
}
#loader.hidden{opacity:0;visibility:hidden;pointer-events:none}
.ld-name{
  font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;
  letter-spacing:.12em;color:var(--gold);
}
.ld-bar-wrap{width:120px;height:1px;background:var(--line)}
.ld-bar{height:100%;width:0;background:linear-gradient(90deg,var(--gold),var(--rust));animation:ldbar 1.5s ease forwards}
@keyframes ldbar{to{width:100%}}

/* ══════════════════════════════════════
   NAV
══════════════════════════════════════ */
nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 3.5rem;height:64px;
  background:rgba(244,241,234,.88);
  backdrop-filter:blur(18px);
  border-bottom:1px solid var(--line2);
  transition:background .3s,border-color .3s;
}
[data-theme="dark"] nav{background:rgba(15,14,12,.88)}
nav.scrolled{border-bottom-color:var(--line)}

.nav-logo{
  font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-weight:600;
  letter-spacing:.04em;color:var(--ink);text-decoration:none;
  display:flex;align-items:center;gap:.3rem;
}
.nav-logo em{font-style:italic;color:var(--rust)}

.nav-links{display:flex;list-style:none}
.nav-links a{
  font-family:'DM Mono',monospace;font-size:.68rem;letter-spacing:.12em;
  text-transform:uppercase;color:var(--muted);text-decoration:none;
  padding:.5rem 1rem;transition:color .2s;position:relative;
}
.nav-links a::after{
  content:'';position:absolute;bottom:0;left:1rem;right:1rem;height:1px;
  background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .25s;
}
.nav-links a:hover{color:var(--ink)}
.nav-links a:hover::after{transform:scaleX(1)}

.nav-right{display:flex;align-items:center;gap:.5rem}
.nav-icon-btn{
  width:34px;height:34px;border-radius:var(--r);
  display:flex;align-items:center;justify-content:center;
  color:var(--muted);text-decoration:none;font-size:.85rem;
  border:1px solid var(--line);background:none;cursor:pointer;
  transition:all .2s;
}
.nav-icon-btn:hover{color:var(--teal);border-color:var(--teal);background:var(--teal-l)}
#theme-btn:hover{color:var(--gold);border-color:var(--gold)}

.hamburger{
  display:none;background:none;border:none;cursor:pointer;
  color:var(--ink);font-size:1rem;padding:.4rem;
}

/* mobile drawer */
.mob-drawer{
  display:none;position:fixed;top:64px;left:0;right:0;z-index:999;
  background:var(--cream);border-bottom:1px solid var(--line);
  padding:1.5rem 2rem;flex-direction:column;gap:.5rem;
}
.mob-drawer.open{display:flex}
.mob-drawer a{
  font-family:'DM Mono',monospace;font-size:.8rem;letter-spacing:.1em;text-transform:uppercase;
  color:var(--muted);text-decoration:none;padding:.7rem 0;border-bottom:1px solid var(--line2);
  transition:color .2s;
}
.mob-drawer a:hover{color:var(--ink)}

/* ══════════════════════════════════════
   HERO
══════════════════════════════════════ */
#hero{
  min-height:100vh;display:grid;grid-template-columns:1.1fr 1fr;
  padding-top:64px;position:relative;overflow:hidden;
}

/* decorative right panel */
.hero-panel{
  position:relative;background:var(--ink);overflow:hidden;
}
.hp-geo{position:absolute;inset:0}
.hp-circle{
  position:absolute;border-radius:50%;border:1px solid rgba(201,168,76,.15);
}
.hp-circle:nth-child(1){width:700px;height:700px;top:-220px;right:-200px}
.hp-circle:nth-child(2){width:480px;height:480px;top:-50px;right:-30px;border-color:rgba(201,168,76,.1)}
.hp-circle:nth-child(3){width:260px;height:260px;top:80px;right:110px;border-color:rgba(201,168,76,.2)}
.hp-vline{position:absolute;width:1px;background:rgba(201,168,76,.1);top:0;bottom:0;left:38%}
.hp-hline{position:absolute;height:1px;background:rgba(201,168,76,.08);left:0;right:0;top:52%}

.hp-content{
  position:absolute;inset:0;z-index:2;
  display:flex;flex-direction:column;justify-content:flex-end;padding:3rem;gap:1.5rem;
}
.hp-status{
  display:inline-flex;align-items:center;gap:.6rem;
  font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;
  color:rgba(244,241,234,.5);
}
.hp-dot{
  width:7px;height:7px;border-radius:50%;background:#4ade80;
  animation:pulse 2s infinite;
}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(74,222,128,.4)}50%{box-shadow:0 0 0 6px rgba(74,222,128,0)}}

.hp-stack-label{
  font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.18em;
  text-transform:uppercase;color:var(--gold);margin-bottom:.75rem;
}
.hp-chips{display:flex;flex-wrap:wrap;gap:.45rem}
.hp-chip{
  font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.04em;
  color:rgba(244,241,234,.6);background:rgba(244,241,234,.06);
  border:1px solid rgba(244,241,234,.1);padding:.28rem .65rem;border-radius:2px;
  transition:all .2s;
}
.hp-chip:hover{border-color:var(--gold);color:var(--gold)}

/* hero left */
.hero-left{
  display:flex;flex-direction:column;justify-content:center;
  padding:5rem 4rem 5rem 5rem;position:relative;z-index:1;
}

.hero-eyebrow{
  display:inline-flex;align-items:center;gap:.6rem;
  font-family:'DM Mono',monospace;font-size:.68rem;letter-spacing:.15em;text-transform:uppercase;
  color:var(--teal);margin-bottom:2rem;
  opacity:0;animation:fadeUp .6s .15s ease forwards;
}
.hero-eyebrow::before{content:'';display:block;width:1.75rem;height:1px;background:var(--teal)}

.hero-name{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(3.5rem,6.5vw,6.5rem);
  font-weight:300;line-height:.92;letter-spacing:-.01em;
  margin-bottom:1.75rem;
  opacity:0;animation:fadeUp .6s .3s ease forwards;
}
.hero-name .italic{font-style:italic;color:var(--rust);display:block}

.hero-subtitle{
  font-family:'DM Mono',monospace;font-size:.8rem;letter-spacing:.08em;
  color:var(--muted);margin-bottom:2.75rem;line-height:1.9;
  opacity:0;animation:fadeUp .6s .45s ease forwards;
}
.hero-subtitle strong{color:var(--teal);font-weight:500}

.hero-cta{
  display:flex;flex-wrap:wrap;gap:.75rem;margin-bottom:3.5rem;
  opacity:0;animation:fadeUp .6s .6s ease forwards;
}

/* buttons */
.btn{
  display:inline-flex;align-items:center;gap:.5rem;
  font-family:'DM Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;
  text-decoration:none;padding:.8rem 1.6rem;border:none;cursor:pointer;
  border-radius:var(--r);transition:all .22s;font-weight:500;
}
.btn-solid{background:var(--ink);color:var(--paper)}
.btn-solid:hover{background:var(--teal);transform:translateY(-2px);box-shadow:0 8px 24px rgba(26,107,107,.2)}
.btn-ghost{background:transparent;color:var(--ink);border:1px solid var(--line)}
.btn-ghost:hover{border-color:var(--ink);background:var(--cream);transform:translateY(-2px)}
.btn-icon-sm{
  padding:.8rem 1.1rem;background:var(--cream);color:var(--muted);
  border:1px solid var(--line);
}
.btn-icon-sm:hover{border-color:var(--teal);color:var(--teal);background:var(--teal-l)}

/* hero stats */
.hero-stats{
  display:flex;gap:3rem;flex-wrap:wrap;
  padding-top:2.5rem;border-top:1px solid var(--line);
  opacity:0;animation:fadeUp .6s .75s ease forwards;
}
.stat-n{
  font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:600;
  line-height:1;color:var(--ink);
}
.stat-n sup{font-size:1.4rem;color:var(--gold)}
.stat-l{
  font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.12em;
  text-transform:uppercase;color:var(--faint);margin-top:.2rem;
}

@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

/* ══════════════════════════════════════
   SHARED SECTION
══════════════════════════════════════ */
.s-wrap{max-width:1200px;margin:0 auto;padding:7rem 3.5rem}
.s-alt{background:var(--cream)}
.s-dark{background:var(--ink);color:var(--paper)}
.s-alt2{background:var(--cream2)}

.s-label{
  font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.2em;
  text-transform:uppercase;color:var(--gold);margin-bottom:.6rem;
  display:flex;align-items:center;gap:.7rem;
}
.s-label::before{content:'';display:block;width:1.5rem;height:1px;background:var(--gold)}
.s-title{
  font-family:'Cormorant Garamond',serif;font-size:clamp(2.2rem,4vw,3.5rem);
  font-weight:300;line-height:1.05;letter-spacing:-.01em;margin-bottom:.9rem;
}
.s-title em{font-style:italic;color:var(--rust)}
.s-dark .s-title em{color:var(--gold-l)}
.s-sub{font-size:.95rem;color:var(--muted);max-width:520px;line-height:1.8;margin-bottom:3.5rem}
.s-dark .s-sub{color:rgba(244,241,234,.5)}

/* ══════════════════════════════════════
   IMPACT
══════════════════════════════════════ */
.impact-grid{
  display:grid;grid-template-columns:repeat(4,1fr);
  border:1px solid var(--line);gap:0;
}
.impact-card{
  padding:2.75rem 2rem;border-right:1px solid var(--line);
  position:relative;overflow:hidden;transition:background .25s;cursor:default;
}
.impact-card:last-child{border-right:none}
.impact-card::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--gold),var(--rust));
  transform:scaleX(0);transform-origin:left;transition:transform .3s;
}
.impact-card:hover{background:var(--cream2)}
.impact-card:hover::after{transform:scaleX(1)}
.ic-icon{font-size:1.5rem;margin-bottom:1.25rem}
.ic-num{
  font-family:'Cormorant Garamond',serif;font-size:3.2rem;font-weight:600;
  line-height:1;color:var(--ink);margin-bottom:.5rem;
}
.ic-num span{color:var(--gold)}
.ic-desc{font-size:.85rem;color:var(--muted);line-height:1.6}

/* ══════════════════════════════════════
   SKILLS
══════════════════════════════════════ */
.skills-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line)}
.sk-card{
  background:var(--paper);padding:2.25rem 2rem;transition:background .22s;cursor:default;
}
[data-theme="dark"] .sk-card{background:var(--cream)}
.sk-card:hover{background:var(--cream)}
[data-theme="dark"] .sk-card:hover{background:var(--cream2)}
.sk-icon{font-size:1.5rem;margin-bottom:1.25rem}
.sk-name{
  font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:600;
  color:var(--ink);margin-bottom:.9rem;
}
.sk-tags{display:flex;flex-wrap:wrap;gap:.35rem}
.stag{
  font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.04em;
  color:var(--muted);background:var(--cream2);border:1px solid var(--line);
  padding:.22rem .6rem;border-radius:2px;transition:all .2s;
}
[data-theme="dark"] .stag{background:var(--cream2);border-color:var(--line2)}
.sk-card:hover .stag{border-color:rgba(201,168,76,.3);color:var(--teal)}

/* ══════════════════════════════════════
   PROJECTS (dark section)
══════════════════════════════════════ */
.filter-row{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:3rem}
.f-btn{
  font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;
  color:rgba(244,241,234,.4);background:none;
  border:1px solid rgba(244,241,234,.1);
  padding:.45rem 1.1rem;border-radius:2rem;cursor:pointer;transition:all .2s;
}
.f-btn:hover{color:rgba(244,241,234,.8);border-color:rgba(244,241,234,.25)}
.f-btn.active{background:var(--gold);border-color:var(--gold);color:var(--ink);font-weight:700}

/* featured */
.featured-card{
  background:rgba(244,241,234,.04);border:1px solid rgba(201,168,76,.2);
  padding:2.5rem;margin-bottom:1.25rem;position:relative;overflow:hidden;
  transition:all .25s;
}
.featured-card::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:3px;
  background:linear-gradient(180deg,var(--gold),var(--rust));
}
.featured-card:hover{border-color:rgba(201,168,76,.4);background:rgba(244,241,234,.06)}
.f-badge{
  display:inline-flex;align-items:center;gap:.4rem;
  font-family:'DM Mono',monospace;font-size:.58rem;letter-spacing:.15em;text-transform:uppercase;
  color:var(--gold);background:rgba(201,168,76,.1);border:1px solid rgba(201,168,76,.2);
  padding:.18rem .65rem;border-radius:2rem;margin-bottom:1rem;
}
.pj-head{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;flex-wrap:wrap;margin-bottom:.75rem}
.pj-title{
  font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:400;color:var(--paper);
}
.pj-links{display:flex;gap:.5rem}
.pj-link{
  font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.08em;text-transform:uppercase;
  color:rgba(244,241,234,.4);text-decoration:none;
  border:1px solid rgba(244,241,234,.1);padding:.3rem .7rem;border-radius:2px;
  display:flex;align-items:center;gap:.35rem;transition:all .2s;
}
.pj-link:hover{color:var(--gold);border-color:var(--gold)}
.pj-desc{font-size:.88rem;color:rgba(244,241,234,.5);line-height:1.75;margin-bottom:1.25rem;max-width:650px}
.pj-impact{
  font-size:.83rem;color:var(--gold);font-family:'DM Mono',monospace;
  display:flex;align-items:center;gap:.5rem;margin-bottom:1.25rem;letter-spacing:.02em;
}
.pj-tech{display:flex;flex-wrap:wrap;gap:.4rem}
.tech-tag{
  font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.04em;
  color:rgba(26,107,107,.9);background:rgba(26,107,107,.12);
  border:1px solid rgba(26,107,107,.2);padding:.22rem .6rem;border-radius:2px;
}

/* project grid */
.pj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(244,241,234,.06)}
.pj-card{
  background:rgba(244,241,234,.02);padding:1.75rem;
  display:flex;flex-direction:column;gap:.85rem;transition:all .25s;
}
.pj-card:hover{background:rgba(244,241,234,.05)}
.pj-card[style*="none"]{display:none}
.pj-card-top{display:flex;justify-content:space-between;align-items:flex-start}
.pj-cat{font-family:'DM Mono',monospace;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(244,241,234,.25)}
.pj-card-title{
  font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:400;color:rgba(244,241,234,.9);
}
.pj-card-desc{font-size:.83rem;color:rgba(244,241,234,.45);line-height:1.7;flex:1}
.pj-metric{
  font-family:'DM Mono',monospace;font-size:.68rem;color:#4ade80;
  display:flex;align-items:center;gap:.4rem;
}
.pj-foot{display:flex;justify-content:space-between;align-items:center;padding-top:.75rem;border-top:1px solid rgba(244,241,234,.06)}

/* ══════════════════════════════════════
   EXPERIENCE
══════════════════════════════════════ */
.exp-list{display:flex;flex-direction:column}
.exp-row{
  display:grid;grid-template-columns:190px 1fr;gap:4rem;
  padding:3rem 0;border-bottom:1px solid var(--line);
}
.exp-meta{}
.exp-period{
  font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.1em;
  text-transform:uppercase;color:var(--faint);margin-bottom:.4rem;
}
.exp-co{
  font-family:'DM Mono',monospace;font-size:.72rem;letter-spacing:.05em;
  color:var(--teal);font-weight:500;
}
.exp-role{
  font-family:'Cormorant Garamond',serif;font-size:1.7rem;font-weight:300;
  color:var(--ink);margin-bottom:.35rem;
}
.exp-badge{
  display:inline-block;font-family:'DM Mono',monospace;font-size:.58rem;
  letter-spacing:.1em;text-transform:uppercase;color:var(--faint);
  border:1px solid var(--line);padding:.18rem .55rem;border-radius:2px;margin-bottom:1.25rem;
}
.exp-pts{list-style:none;display:flex;flex-direction:column;gap:.55rem}
.exp-pts li{
  font-size:.88rem;color:var(--muted);padding-left:1.4rem;position:relative;line-height:1.7;
}
.exp-pts li::before{content:'→';position:absolute;left:0;color:var(--gold);font-size:.8rem}
.exp-pts li strong{color:var(--ink);font-weight:600}

/* ══════════════════════════════════════
   EDUCATION & CERTS
══════════════════════════════════════ */
.edu-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem}
.edu-box{
  background:var(--paper);border:1px solid var(--line);padding:2.5rem;
  position:relative;overflow:hidden;
}
[data-theme="dark"] .edu-box{background:var(--cream2)}
.edu-box::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--gold),var(--rust));
}
.edu-school{
  font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:600;
  color:var(--ink);margin-bottom:.4rem;
}
.edu-deg{font-size:.88rem;color:var(--muted);margin-bottom:1.75rem;line-height:1.5}
.edu-kpis{display:flex;gap:2.5rem}
.edu-kpi-val{
  font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-weight:600;
  color:var(--teal);line-height:1;
}
.edu-kpi-key{
  font-family:'DM Mono',monospace;font-size:.58rem;letter-spacing:.12em;
  text-transform:uppercase;color:var(--faint);margin-top:.2rem;
}

.lang-box{
  background:var(--paper);border:1px solid var(--line);padding:2rem;margin-top:1.25rem;
}
[data-theme="dark"] .lang-box{background:var(--cream2)}
.lang-head{
  font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.15em;
  text-transform:uppercase;color:var(--faint);margin-bottom:1.25rem;
}
.lang-row{margin-bottom:1rem}
.lang-info{display:flex;justify-content:space-between;margin-bottom:.4rem}
.lang-name{font-size:.9rem;font-weight:600;color:var(--ink)}
.lang-lvl{font-family:'DM Mono',monospace;font-size:.62rem;color:var(--faint)}
.lang-track{height:2px;background:var(--cream2);border-radius:1px}
.lang-fill{height:100%;background:linear-gradient(90deg,var(--teal),var(--gold));border-radius:1px}

.certs-stack{display:flex;flex-direction:column;gap:.65rem}
.cert-row{
  display:flex;align-items:center;gap:1rem;padding:1rem 1.25rem;
  background:var(--paper);border:1px solid var(--line);transition:all .22s;
}
[data-theme="dark"] .cert-row{background:var(--cream2)}
.cert-row:hover{border-color:var(--gold);background:var(--cream)}
[data-theme="dark"] .cert-row:hover{background:var(--cream)}
.cert-ico{color:var(--gold);font-size:.85rem;flex-shrink:0}
.cert-info{flex:1}
.cert-name{font-size:.88rem;font-weight:600;color:var(--ink)}
.cert-by{font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.05em;color:var(--faint)}
.cert-verified{
  font-family:'DM Mono',monospace;font-size:.55rem;letter-spacing:.1em;text-transform:uppercase;
  color:var(--teal);background:var(--teal-l);border:1px solid rgba(26,107,107,.2);
  padding:.15rem .5rem;border-radius:2rem;
}

/* ══════════════════════════════════════
   CONTACT
══════════════════════════════════════ */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start}
.contact-headline{
  font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,5vw,4.2rem);
  font-weight:300;line-height:1.0;letter-spacing:-.01em;color:var(--ink);margin-bottom:1.5rem;
}
.contact-headline em{font-style:italic;color:var(--rust)}
.contact-sub{font-size:.93rem;color:var(--muted);line-height:1.8;margin-bottom:2.5rem}
.c-links{display:flex;flex-direction:column;gap:.65rem}
.c-link{
  display:flex;align-items:center;gap:1rem;padding:1.1rem 1.35rem;
  background:var(--paper);border:1px solid var(--line);text-decoration:none;color:var(--ink);
  transition:all .22s;
}
[data-theme="dark"] .c-link{background:var(--cream)}
.c-link:hover{border-color:var(--teal);background:var(--teal-l);transform:translateX(5px)}
.c-link-ico{font-size:.9rem;color:var(--faint);width:18px;transition:color .2s}
.c-link:hover .c-link-ico{color:var(--teal)}
.c-link-meta{}
.c-link-lbl{font-family:'DM Mono',monospace;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--faint)}
.c-link-val{font-size:.9rem;font-weight:600;color:var(--ink)}

.c-form{
  background:var(--cream);border:1px solid var(--line);padding:2.5rem;
}
[data-theme="dark"] .c-form{background:var(--cream2)}
.c-form-title{
  font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:300;
  color:var(--ink);margin-bottom:1.75rem;
}
.fg{margin-bottom:1.1rem}
.fg label{
  font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;
  color:var(--faint);display:block;margin-bottom:.45rem;
}
.fg input,.fg textarea{
  width:100%;background:var(--paper);border:1px solid var(--line);
  padding:.8rem 1rem;color:var(--ink);font-family:'Outfit',sans-serif;font-size:.9rem;
  transition:border-color .2s;outline:none;resize:none;
}
[data-theme="dark"] .fg input,[data-theme="dark"] .fg textarea{background:var(--cream)}
.fg input:focus,.fg textarea:focus{border-color:var(--teal)}
.fg textarea{height:100px}

/* ══════════════════════════════════════
   FOOTER
══════════════════════════════════════ */
footer{
  background:var(--ink2);border-top:1px solid var(--line);
  padding:1.75rem 3.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;
}
[data-theme="dark"] footer{background:var(--cream)}
.foot-copy{
  font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.08em;
  color:rgba(244,241,234,.3);
}
[data-theme="dark"] .foot-copy{color:var(--faint)}
.foot-copy strong{color:var(--gold)}
.foot-icons{display:flex;gap:.5rem}
.foot-ico{
  width:30px;height:30px;border-radius:var(--r);
  display:flex;align-items:center;justify-content:center;
  color:rgba(244,241,234,.3);font-size:.78rem;text-decoration:none;
  border:1px solid rgba(244,241,234,.08);transition:all .2s;
}
[data-theme="dark"] .foot-ico{color:var(--faint);border-color:var(--line)}
.foot-ico:hover{color:var(--gold);border-color:var(--gold)}

/* ══════════════════════════════════════
   STICKY MOBILE CTA
══════════════════════════════════════ */
.sticky-hire{
  display:none;position:fixed;bottom:1.25rem;right:1.25rem;z-index:900;
}
.sticky-hire a{
  display:flex;align-items:center;gap:.5rem;
  font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;
  color:var(--paper);background:var(--ink);
  padding:.8rem 1.5rem;text-decoration:none;font-weight:700;
  box-shadow:0 4px 20px rgba(0,0,0,.2);transition:all .2s;
}
.sticky-hire a:hover{background:var(--teal);transform:translateY(-2px)}

/* ══════════════════════════════════════
   SCROLL REVEAL
══════════════════════════════════════ */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .65s ease,transform .65s ease}
.reveal.in{opacity:1;transform:translateY(0)}

/* ══════════════════════════════════════
   RESPONSIVE — MOBILE-FIRST SYSTEM
   Breakpoints: 320 | 480 | 768 | 1024 | 1440
══════════════════════════════════════ */

/* Global safe defaults */
img, video, svg { max-width: 100%; height: auto; }
*, *::before, *::after { box-sizing: border-box; }

/* 320–479px: small phones */
@media (max-width: 479px) {
  html { font-size: 14px; }
  body { overflow-x: hidden; }
  nav { padding: 0 1rem; height: 56px; }
  .nav-links { display: none; }
  .hamburger { display: block; }
  .mob-drawer { top: 56px; padding: 1.25rem 1rem; }
  .nav-right > a.nav-icon-btn { display: none; }
  #hero { grid-template-columns: 1fr; padding-top: 56px; min-height: auto; }
  .hero-panel { display: none; }
  .hero-left { padding: 2.5rem 1rem 3rem; }
  .hero-name { font-size: clamp(2.2rem, 9vw, 3rem); line-height: 1; margin-bottom: 1.25rem; }
  .hero-eyebrow { font-size: .6rem; margin-bottom: 1.25rem; }
  .hero-subtitle { font-size: .72rem; margin-bottom: 1.75rem; }
  .hero-cta { gap: .5rem; flex-wrap: wrap; }
  .btn { font-size: .62rem; padding: .65rem 1rem; }
  .hero-stats { gap: 1.25rem; padding-top: 1.5rem; flex-wrap: wrap; }
  .stat-n { font-size: 2rem; }
  .s-wrap { padding: 3rem 1rem; }
  .s-title { font-size: clamp(1.7rem, 7vw, 2.4rem); }
  .impact-grid { grid-template-columns: 1fr; }
  .impact-card { border-right: none; border-bottom: 1px solid var(--line); padding: 1.75rem 1.25rem; }
  .impact-card:last-child { border-bottom: none; }
  .skills-grid { grid-template-columns: 1fr; }
  .pj-grid { grid-template-columns: 1fr; }
  .featured-card { padding: 1.5rem 1rem; }
  .filter-row { gap: .35rem; }
  .f-btn { font-size: .6rem; padding: .38rem .8rem; }
  .exp-row { grid-template-columns: 1fr; gap: .5rem; padding: 2rem 0; }
  .exp-role { font-size: 1.3rem; }
  .edu-grid { grid-template-columns: 1fr; gap: 1.5rem; }
  .edu-box { padding: 1.5rem 1.25rem; }
  .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
  .contact-headline { font-size: clamp(2rem, 7vw, 2.8rem); }
  .c-form { padding: 1.5rem 1.25rem; }
  .resume-layout { grid-template-columns: 1fr; gap: 2rem; }
  .resume-sidebar { position: static; }
  .rv-skills-grid { grid-template-columns: 1fr; gap: 1rem 2rem; }
  .rv-certs { grid-template-columns: 1fr; }
  .rv-tl-item { grid-template-columns: 1fr; gap: .35rem; }
  .rv-tl-period { padding-top: 0; }
  footer { padding: 1.25rem 1rem; flex-direction: column; align-items: flex-start; gap: .75rem; }
  .sticky-hire { display: block; }
}

/* 480–767px: large phones */
@media (min-width: 480px) and (max-width: 767px) {
  html { font-size: 15px; }
  body { overflow-x: hidden; }
  nav { padding: 0 1.25rem; height: 60px; }
  .nav-links { display: none; }
  .hamburger { display: block; }
  .mob-drawer { top: 60px; }
  .nav-right > a.nav-icon-btn { display: none; }
  #hero { grid-template-columns: 1fr; padding-top: 60px; min-height: auto; }
  .hero-panel { display: none; }
  .hero-left { padding: 3rem 1.5rem 3.5rem; }
  .hero-name { font-size: clamp(2.8rem, 8vw, 4rem); }
  .hero-stats { gap: 1.5rem; flex-wrap: wrap; }
  .s-wrap { padding: 4rem 1.5rem; }
  .impact-grid { grid-template-columns: 1fr 1fr; }
  .impact-card { border-bottom: 1px solid var(--line); border-right: 1px solid var(--line); }
  .impact-card:nth-child(2n) { border-right: none; }
  .impact-card:nth-child(3), .impact-card:nth-child(4) { border-bottom: none; }
  .skills-grid { grid-template-columns: 1fr; }
  .pj-grid { grid-template-columns: 1fr; }
  .exp-row { grid-template-columns: 1fr; gap: .6rem; }
  .edu-grid { grid-template-columns: 1fr; }
  .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  .resume-layout { grid-template-columns: 1fr; gap: 2.5rem; }
  .resume-sidebar { position: static; }
  .rv-skills-grid { grid-template-columns: 1fr 1fr; }
  .rv-certs { grid-template-columns: 1fr; }
  .rv-tl-item { grid-template-columns: 1fr; gap: .4rem; }
  footer { padding: 1.5rem 1.25rem; }
  .sticky-hire { display: block; }
}

/* 768–1023px: tablets */
@media (min-width: 768px) and (max-width: 1023px) {
  nav { padding: 0 2rem; }
  .nav-links { display: none; }
  .hamburger { display: block; }
  #hero { grid-template-columns: 1fr; }
  .hero-panel { display: none; }
  .hero-left { padding: 4rem 2.5rem; }
  .s-wrap { padding: 5rem 2rem; }
  .impact-grid { grid-template-columns: repeat(2, 1fr); }
  .impact-card { border-bottom: 1px solid var(--line); border-right: 1px solid var(--line); }
  .impact-card:nth-child(2n) { border-right: none; }
  .impact-card:nth-child(3), .impact-card:nth-child(4) { border-bottom: none; }
  .skills-grid { grid-template-columns: repeat(2, 1fr); }
  .pj-grid { grid-template-columns: repeat(2, 1fr); }
  .exp-row { grid-template-columns: 140px 1fr; gap: 2rem; }
  .edu-grid { grid-template-columns: 1fr; }
  .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
  .resume-layout { grid-template-columns: 240px 1fr; gap: 2.5rem; }
  .rv-skills-grid { grid-template-columns: 1fr 1fr; }
  .rv-certs { grid-template-columns: 1fr; }
  footer { padding: 1.5rem 2rem; }
  .sticky-hire { display: block; }
}

/* 1024–1439px: laptops */
@media (min-width: 1024px) and (max-width: 1439px) {
  .nav-links { display: flex; }
  .hamburger { display: none; }
  .mob-drawer { display: none !important; }
  #hero { grid-template-columns: 1.1fr 1fr; }
  .hero-panel { display: block; }
  .hero-left { padding: 5rem 4rem 5rem 3.5rem; }
  .s-wrap { padding: 6rem 3rem; }
  .impact-grid { grid-template-columns: repeat(4, 1fr); }
  .skills-grid { grid-template-columns: repeat(3, 1fr); }
  .pj-grid { grid-template-columns: repeat(3, 1fr); }
  .edu-grid { grid-template-columns: 1fr 1fr; }
  .contact-grid { grid-template-columns: 1fr 1fr; gap: 4rem; }
  .resume-layout { grid-template-columns: 260px 1fr; gap: 3.5rem; }
  .rv-skills-grid { grid-template-columns: 1fr 1fr; }
  .rv-certs { grid-template-columns: 1fr 1fr; }
}

/* 1440px+: large screens */
@media (min-width: 1440px) {
  html { font-size: 17px; }
  .s-wrap { max-width: 1360px; padding: 8rem 4rem; }
  nav { padding: 0 4rem; height: 70px; }
  .hero-left { padding: 6rem 5rem; }
}
/* ══════════════════════════════════════
   RESUME SECTION
══════════════════════════════════════ */
#resume { background: var(--cream); }
.resume-layout { display: grid; grid-template-columns: 280px 1fr; gap: 4rem; align-items: start; }
.resume-sidebar { position: sticky; top: 90px; }
.resume-avatar-ring { width: 88px; height: 88px; border-radius: 50%; border: 1px solid var(--line); display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; position: relative; overflow: hidden; }
.resume-avatar-ring::before { content: ''; position: absolute; inset: 0; border-radius: 50%; border: 2px solid transparent; border-top-color: var(--gold); border-right-color: var(--rust); animation: spin-ring 3s linear infinite; }
@keyframes spin-ring { to { transform: rotate(360deg); } }
.resume-avatar-inner { width: 72px; height: 72px; border-radius: 50%; background: linear-gradient(135deg, var(--teal), var(--ink)); display: flex; align-items: center; justify-content: center; font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; font-weight: 600; color: var(--paper); z-index: 1; }
.resume-name-block { margin-bottom: 2rem; }
.resume-name-block h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 600; color: var(--ink); line-height: 1.1; margin-bottom: .25rem; }
.resume-name-block p { font-family: 'DM Mono', monospace; font-size: .62rem; letter-spacing: .1em; text-transform: uppercase; color: var(--teal); }
.resume-contact-list { display: flex; flex-direction: column; gap: .65rem; margin-bottom: 2rem; }
.rcl-item { display: flex; align-items: center; gap: .75rem; font-size: .82rem; color: var(--muted); }
.rcl-icon { width: 28px; height: 28px; border-radius: 4px; background: var(--paper); border: 1px solid var(--line); display: flex; align-items: center; justify-content: center; font-size: .7rem; color: var(--faint); flex-shrink: 0; transition: all .2s; }
.rcl-item:hover .rcl-icon { border-color: var(--teal); color: var(--teal); background: var(--teal-l); }
.resume-download-btn { display: flex; align-items: center; gap: .6rem; font-family: 'DM Mono', monospace; font-size: .65rem; letter-spacing: .1em; text-transform: uppercase; color: var(--paper); background: var(--ink); border: none; cursor: pointer; padding: .85rem 1.4rem; border-radius: var(--r); transition: all .25s; width: 100%; justify-content: center; text-decoration: none; position: relative; overflow: hidden; }
.resume-download-btn::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, var(--teal), transparent); opacity: 0; transition: opacity .3s; }
.resume-download-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26,107,107,.25); }
.resume-download-btn:hover::before { opacity: 1; }
.resume-download-btn .dl-arrow { display: inline-block; animation: bob 1.8s ease-in-out infinite; }
@keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(3px); } }
.resume-body { display: flex; flex-direction: column; gap: 3rem; }
.rv-section-label { font-family: 'DM Mono', monospace; font-size: .6rem; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.25rem; display: flex; align-items: center; gap: .65rem; }
.rv-section-label::after { content: ''; flex: 1; height: 1px; background: var(--line); }
.rv-timeline { display: flex; flex-direction: column; gap: 0; }
.rv-tl-item { display: grid; grid-template-columns: 130px 1fr; gap: 2rem; padding: 1.5rem 0; border-bottom: 1px solid var(--line2); opacity: 0; transform: translateX(-16px); transition: opacity .5s ease, transform .5s ease; }
.rv-tl-item.in { opacity: 1; transform: translateX(0); }
.rv-tl-item:last-child { border-bottom: none; }
.rv-tl-period { font-family: 'DM Mono', monospace; font-size: .62rem; letter-spacing: .08em; color: var(--faint); padding-top: .3rem; text-transform: uppercase; line-height: 1.7; }
.rv-tl-role { font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; font-weight: 600; color: var(--ink); margin-bottom: .15rem; }
.rv-tl-company { font-family: 'DM Mono', monospace; font-size: .62rem; letter-spacing: .06em; color: var(--teal); margin-bottom: .65rem; }
.rv-tl-pts { list-style: none; display: flex; flex-direction: column; gap: .35rem; }
.rv-tl-pts li { font-size: .84rem; color: var(--muted); padding-left: 1.2rem; position: relative; line-height: 1.65; }
.rv-tl-pts li::before { content: ''; position: absolute; left: 0; top: .55em; width: 5px; height: 1px; background: var(--gold); }
.rv-skills-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem 3rem; }
.rv-skill-top { display: flex; justify-content: space-between; margin-bottom: .5rem; }
.rv-skill-name { font-size: .84rem; color: var(--ink); font-weight: 500; }
.rv-skill-pct { font-family: 'DM Mono', monospace; font-size: .62rem; color: var(--faint); }
.rv-skill-bar { height: 2px; background: var(--line); border-radius: 1px; overflow: hidden; }
.rv-skill-fill { height: 100%; width: 0; background: linear-gradient(90deg, var(--teal), var(--gold)); border-radius: 1px; transition: width 1.2s cubic-bezier(.22,1,.36,1); }
.rv-skill-item.in .rv-skill-fill { width: var(--w); }
.rv-tags { display: flex; flex-wrap: wrap; gap: .4rem; }
.rv-tag { font-family: 'DM Mono', monospace; font-size: .6rem; letter-spacing: .04em; color: var(--muted); background: var(--paper); border: 1px solid var(--line); padding: .25rem .7rem; border-radius: 2px; transition: all .2s; }
.rv-tag:hover { border-color: var(--gold); color: var(--teal); }
.rv-projects { display: flex; flex-direction: column; gap: .75rem; }
.rv-pj { display: flex; gap: 1rem; align-items: flex-start; padding: 1rem 1.2rem; background: var(--paper); border: 1px solid var(--line); opacity: 0; transform: translateY(10px); transition: opacity .4s ease, transform .4s ease, background .22s, border-color .22s; }
.rv-pj.in { opacity: 1; transform: translateY(0); }
.rv-pj:hover { border-color: rgba(201,168,76,.3); background: var(--cream2); }
.rv-pj-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); flex-shrink: 0; margin-top: .45rem; animation: dot-pulse 2.5s ease-in-out infinite; }
@keyframes dot-pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: .4; transform: scale(.6); } }
.rv-pj-name { font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-weight: 600; color: var(--ink); margin-bottom: .2rem; }
.rv-pj-desc { font-size: .8rem; color: var(--muted); line-height: 1.6; }
.rv-edu { display: flex; flex-direction: column; gap: .4rem; padding: 1.5rem; background: var(--paper); border: 1px solid var(--line); position: relative; overflow: hidden; }
[data-theme="dark"] .rv-edu { background: var(--cream2); }
.rv-edu::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: linear-gradient(180deg, var(--gold), var(--rust)); }
.rv-edu-deg { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 600; color: var(--ink); }
.rv-edu-inst { font-family: 'DM Mono', monospace; font-size: .65rem; letter-spacing: .06em; color: var(--teal); }
.rv-edu-meta { font-size: .8rem; color: var(--faint); margin-top: .2rem; }
.rv-certs { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem; }
.rv-cert { display: flex; align-items: center; gap: .65rem; padding: .75rem 1rem; background: var(--paper); border: 1px solid var(--line); font-size: .8rem; color: var(--muted); transition: all .2s; }
[data-theme="dark"] .rv-cert { background: var(--cream2); }
.rv-cert:hover { border-color: rgba(201,168,76,.3); color: var(--ink); }
.rv-cert-line { width: 3px; height: 20px; border-radius: 2px; flex-shrink: 0; background: linear-gradient(180deg, var(--gold), var(--teal)); }
</style>
</head>
<body>

<!-- LOADER -->
<div id="loader">
  <div class="ld-name">Gokul Raj</div>
  <div class="ld-bar-wrap"><div class="ld-bar"></div></div>
</div>

<!-- NAV -->
<nav id="nav">
  <a href="#hero" class="nav-logo">Gokul <em>Raj</em></a>
  <ul class="nav-links">
    <li><a href="#impact">Impact</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#experience">Experience</a></li>
    <li><a href="#education">Education</a></li>
    <li><a href="#contact">Contact</a></li>
    <li><a href="#resume">Resume</a></li>
  </ul>
  <div class="nav-right">
    <a href="https://www.linkedin.com/in/gokulraj077" target="_blank" class="nav-icon-btn" title="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
    <a href="https://github.com/gokul2005083-source" target="_blank" class="nav-icon-btn" title="GitHub"><i class="fab fa-github"></i></a>
    <button class="nav-icon-btn" id="theme-btn" title="Toggle theme"><i class="fas fa-moon" id="theme-ico"></i></button>
    <button class="hamburger" id="ham"><i class="fas fa-bars"></i></button>
  </div>
